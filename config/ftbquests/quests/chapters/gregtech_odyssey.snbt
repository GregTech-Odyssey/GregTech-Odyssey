	quests: [
		{
			description: [
				"&a看到有这么多章节，不知道从何入手？"
				""
				"&a以下是推荐阅读优先级："
				""
				"[\"\",{\"color\":\"yellow\",\"text\":\"⭐在砍下第一棵树前建议前往\"},{ \"text\": \"提示\", \"underlined\": \"true\",\"color\":\"aqua\", \"clickEvent\": { \"action\": \"change_page\", \"value\": \"79646E8E449D8A1A\"} },{\"color\":\"yellow\",\"text\":\"章节查看提示，花几分钟阅读一下对你的游玩之旅大有帮助\"}]"
				""
				"&e⭐沿着&b主线&r&e推进科技"
				""
				"&b应用能源&r以及&b魔法线（魔力导论\\&英雄之路）&r是两个比较重要的支线，你可以等主线需要它们，或想提升体验时查看"
				""
				"其他支线如神化、化工、矿物处理、食物等，按任务需求或个人兴趣穿插阅读即可"
				""
				"以更舒服的姿势体验&cGregtech:Odyssey&r之旅！"
			]
			icon: "minecraft:writable_book"
			id: "19EFE14C82DDAB67"
			rewards: [{
				id: "52494ADABA776912"
